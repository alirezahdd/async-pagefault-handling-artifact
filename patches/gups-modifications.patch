+/* ===========================================================================
+ * PERF-RELATED FUNCTIONS
+ * Setup / start / stop / cleanup perf counters
+ * ========================================================================== */
+struct perf_counters {
+    int fd_user_time;
+    int fd_kernel_time;
+    int fd_user_instr;
+    int fd_kernel_instr;
+};
+
+struct perf_counters perf_ctrs;
